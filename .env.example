# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=replace_with_strong_password

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://admin:replace_with_strong_password@mongo:27017/ecommerce?authSource=admin

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=replace_with_256bit_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# Cloudinary — https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — must match your frontend origin exactly
CLIENT_ORIGIN=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
INTERNAL_SECRET=replace_with_secure_internal_shared_secret
AUTO_GENERATE_3D=true

# Claid.ai — Virtual Try-On API — https://docs.claid.ai
CLAID_API_KEY=your_claid_api_key

# Razorpay — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
